{
  "name": "@bitfinex/bfx-report-express",
  "version": "3.0.0",
  "description": "Express server of reporting tool",
  "main": "index.js",
  "engines": {
    "node": ">=16.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bitfinexcom/bfx-report-express.git"
  },
  "license": "Apache-2.0",
  "contributors": [
    "Vladimir Voronkov <vsvoronkov@gmail.com>",
    "Paolo Ardoino <paolo@btifinex.com>",
    "Ezequiel Wernicke <ezequiel.wernicke@bitfinex.com>"
  ],
  "keywords": [
    "bitfinex"
  ],
  "bugs": {
    "url": "https://github.com/bitfinexcom/bfx-report-express/issues"
  },
  "homepage": "https://github.com/bitfinexcom/bfx-report-express#readme",
  "dependencies": {
    "colors": "1.4.0",
    "config": "4.4.1",
    "cors": "2.8.6",
    "debug": "4.4.3",
    "express": "4.22.1",
    "grenache-nodejs-http": "1.0.1",
    "grenache-nodejs-link": "1.0.2",
    "grenache-nodejs-ws": "1.0.0",
    "morgan": "1.10.1",
    "winston": "3.19.0",
    "ws": "8.19.0"
  },
  "devDependencies": {
    "@bitfinex/bfx-report": "git+https://github.com/bitfinexcom/bfx-report.git",
    "chai": "4.5.0",
    "cross-env": "10.1.0",
    "mocha": "11.7.5",
    "nodemon": "3.1.11",
    "standard": "17.1.2",
    "supertest": "7.2.2"
  },
  "standard": {
    "globals": [
      "describe",
      "it",
      "before",
      "after",
      "beforeEach",
      "afterEach"
    ]
  },
  "nodemonConfig": {
    "verbose": true,
    "ignore": [
      "node_modules/",
      "logs/",
      ".git/",
      ".idea/",
      ".vscode/"
    ]
  },
  "scripts": {
    "start": "cross-env NODE_ENV=development nodemon index.js",
    "test": "standard && cross-env NODE_ENV=test mocha './test/**/*.spec.js' --config .mocharc.json"
  }
}
